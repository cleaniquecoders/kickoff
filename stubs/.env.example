# IMPORTANT: Change all CHANGE_ME_BEFORE_DEPLOY values before deploying to any environment
APP_NAME="${PROJECT_NAME}"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

MEDIA_DISK=media

SUPERADMIN_NAME="tech"
SUPERADMIN_EMAIL="tech@kickoff.my"
SUPERADMIN_PASSWORD="StrongPassword1234^|"

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=${PROJECT_NAME}
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
# null = no auth, so local/passwordless Redis works out of the box.
# Set a strong password before deploying (docker-compose applies it via --requirepass).
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="support@kickoff.my"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
# Enabled by default, but only the exception watcher records (all other watchers
# below are off). Dashboard access is still gated to local/staging via access.telescope.
TELESCOPE_ENABLED=true
TELESCOPE_BATCH_WATCHER=false
TELESCOPE_CACHE_WATCHER=false
TELESCOPE_CLIENT_REQUEST_WATCHER=false
TELESCOPE_COMMAND_WATCHER=false
TELESCOPE_DUMP_WATCHER=false
TELESCOPE_DUMP_WATCHER_ALWAYS=false
TELESCOPE_EVENT_WATCHER=false
TELESCOPE_EXCEPTION_WATCHER=true
TELESCOPE_GATE_WATCHER=false
TELESCOPE_JOB_WATCHER=false
TELESCOPE_LOG_WATCHER=false
TELESCOPE_MAIL_WATCHER=false
TELESCOPE_MODEL_WATCHER=false
TELESCOPE_NOTIFICATION_WATCHER=false
TELESCOPE_QUERY_WATCHER=false
TELESCOPE_REDIS_WATCHER=false
TELESCOPE_REQUEST_WATCHER=false
TELESCOPE_RESPONSE_SIZE_LIMIT=64
TELESCOPE_SCHEDULE_WATCHER=false
TELESCOPE_VIEW_WATCHER=false

# Laravel MCP Kit (cleaniquecoders/laravel-mcp-kit)
# Ships a ready-to-use "tasks" MCP server. Master switch + per-transport toggles.
# Set MCP_KIT_ENABLED=false to disable everything; MCP_KIT_WEB_ENABLED=false to keep
# only the local STDIO transport (php artisan mcp:start) without exposing the HTTP endpoint.
# Auth is token-only (auth:sanctum) by default; set MCP_KIT_WEB_OAUTH_ENABLED=true for OAuth 2.1.
MCP_KIT_ENABLED=true
MCP_KIT_LOCAL_ENABLED=true
MCP_KIT_WEB_ENABLED=true
MCP_KIT_WEB_PATH=mcp/tasks
MCP_KIT_WEB_OAUTH_ENABLED=false

MINIO_KEY=
MINIO_SECRET=
MINIO_BUCKET=${PROJECT_NAME}

# Docker Services
DB_ROOT_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
MAILPIT_UI_PORT=8025
MEILI_MASTER_KEY=CHANGE_ME_BEFORE_DEPLOY
MEILI_NO_ANALYTICS=true
MEILI_ENV=development
MEILI_DB_PATH=/data.ms
MEILI_PORT=7700
MINIO_ROOT_USER=CHANGE_ME_BEFORE_DEPLOY
MINIO_ROOT_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_GPG_RECIPIENT=

# Audit
AUDIT_CONSOLE=true

# Security
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_MIXED_CASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_REQUIRE_UNCOMPROMISED=true

# Authentication
# Fresh-install default for public self-service registration. Overridden at
# runtime by Admin > Settings > Authentication. When false, only admins add users.
REGISTRATION_ENABLED=true

# Webhooks (cleaniquecoders/laravel-config-webhook)
CONFIG_WEBHOOK_FEATURE=true
CONFIG_WEBHOOK_QUEUE=webhooks

# Config Backup (cleaniquecoders/laravel-config-backup)
CONFIG_BACKUP_ENABLED=true
CONFIG_BACKUP_DISK=local
CONFIG_BACKUP_RETENTION=10
# Scheduled backups (off by default — set a strong password before enabling)
#CONFIG_BACKUP_SCHEDULE=true
#CONFIG_BACKUP_SCHEDULE_CRON="0 2 * * *"
#CONFIG_BACKUP_SCHEDULE_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
#CONFIG_BACKUP_NOTIFICATIONS=true
#CONFIG_BACKUP_NOTIFICATION_MAIL=admin@example.com

# SSO (cleaniquecoders/laravel-config-sso)
CONFIG_SSO_FEATURE=true

# Artisan Runner (cleaniquecoders/laravel-artisan-runner) — superadmin only
ARTISAN_RUNNER_NOTIFY_EMAIL=

# SEO & Analytics
# First-boot defaults only — admin-editable at Admin > Settings > SEO & Analytics
# once migrated. Snippets render only when an ID is set.
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
GOOGLE_SITE_VERIFICATION=
